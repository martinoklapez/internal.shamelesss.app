# Copy to .env.local and fill in values.
#
# Supabase (required for most admin features)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=  # Creator Pipeline API + avatar uploads (server only)
#
# UUID of the Shamelesss app user account used when admins send messages from Support Chat.
# Must match auth.users.id / profiles.user_id.
SUPPORT_CHAT_USER_ID=

# Server-side Google Cloud Translation API key (Basic / API key restriction recommended).
# Used only by /api/translate; never expose to the browser.
GOOGLE_TRANSLATE_API_KEY=

# Creator CRM workers (outreach + Quick Add scrape queue; edge function cron)
CREATOR_OUTREACH_CRON_SECRET=
# Quick Add scrape batch size per worker run (default 3, max 10)
# QUICK_ADD_WORKER_BATCH_SIZE=3

# Missive — creator outreach sends (POST /v1/drafts, lib/creator-outreach/missive.ts)
MISSIVE_API_TOKEN=
# From addresses are configured in the app: Pipeline → Senders, then per contact type in Rules.
# Optional fallback display name when a sender row has no display_name set
# MISSIVE_FROM_NAME=Shamelesss
# Shared inbox: team + org UUIDs (Missive → Settings → API → Resource IDs)
MISSIVE_TEAM_ID=
MISSIVE_ORGANIZATION_ID=
# Optional shared Gmail account ID fallback if not set on each sender in Pipeline → Senders
# MISSIVE_ACCOUNT_ID=46396c31-9a60-4c69-9693-79004c637731
# When the configured alias cannot API-send, fall back to the token user's email (default: allowed)
# MISSIVE_ALLOW_PERSONAL_FALLBACK=false

# Chrome extension (chrome-extension/config.js): same NEXT_PUBLIC_SUPABASE_* + app URL
# Missive iframe: register https://<your-app>/integrations/missive in Missive → Integrations

# Apify — reliable Instagram/TikTok profile import in Creator Pipeline Quick Add
# Instagram: https://apify.com/apify/instagram-profile-scraper
# TikTok profile: https://apify.com/clockworks/tiktok-profile-scraper
# TikTok fallback: https://apify.com/clockworks/tiktok-scraper
APIFY_API_TOKEN=
# Optional actor overrides (defaults shown)
# APIFY_INSTAGRAM_PROFILE_ACTOR_ID=apify/instagram-profile-scraper
# APIFY_TIKTOK_PROFILE_ACTOR_ID=clockworks/tiktok-profile-scraper
# APIFY_TIKTOK_SCRAPER_ACTOR_ID=clockworks/tiktok-scraper